# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Enterprise HR Policy Assistant"
APP_ENV=production
APP_DEBUG=false
API_V1_PREFIX=/api/v1

# Set to your Vercel frontend URL (no trailing slash)
FRONTEND_ORIGIN=https://your-app.vercel.app

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Storage ───────────────────────────────────────────────────────────────────
RAW_DOCS_DIR=./data/raw_docs
PROCESSED_DATA_DIR=./data/processed
VECTOR_STORE_DIR=./data/processed/vector_store

# Use "local_json" for demo/free tier (data is bundled in Docker image)
# Use "pinecone" for production (persistent across deploys)
VECTOR_STORE_PROVIDER=local_json

# ── Pinecone (only when VECTOR_STORE_PROVIDER=pinecone) ───────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=hr-policy-assistant
PINECONE_NAMESPACE=production
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=86400

# Change this before deploying!
ADMIN_PASSWORD=change-me-strong-password

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=
SMTP_USE_TLS=true
HR_CONTACT_EMAIL=hr@yourcompany.com

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_TRACING=false
